      "id": "agent-status.pi-hook-liveness",
      "title": "Pi status hooks cannot stall a turn or complete a live runtime",
      "maturity": "experimental",
      "protection": "partial",
      "owner": "agent-session",
      "layer": "main-provider-contract",
      "surfaces": [
